<h2>Roulette</h2>
<form method="POST">
  <label>Amount:</label>
  <input type="number" name="bet_amount" min="1" required>
  <label>Color:</label>
  <select name="bet_color" required>
    <option value="red">Red</option>
    <option value="black">Black</option>
    <option value="green">Green (0)</option>
  </select>
  <button type="submit">Bet</button>
</form>
